{
  "version": "1.0",
  "description": "古籍数字资源来源站点目录。Book.resources / Work.resources 中 resource.id 应是本表中的 source.id。",
  "updated_at": "2026-05-15",

  "tier_definitions": {
    "1": {
      "label": "原图书馆 / 官方来源",
      "description": "原藏机构数字化平台、国家级 / 馆藏官方",
      "default_policy": "preserve",
      "import_strategy": "全收 — 有多少录多少"
    },
    "2": {
      "label": "国外可访问资源库",
      "description": "Internet Archive / Wikimedia / HathiTrust 等国际公共平台",
      "default_policy": "preserve",
      "import_strategy": "都录入；若 tier 1-4 全无，从 tier 5 下载后上传 IA 作镜像"
    },
    "3": {
      "label": "国内稳定下载网站",
      "description": "书格 / 识典古籍 / CText / 维基文库等国内可达的整理或影印站点",
      "default_policy": "preserve",
      "import_strategy": "录一个最好的（择优），不重复"
    },
    "4": {
      "label": "自家备份",
      "description": "百度网盘等我们做的镜像（条件性收录）",
      "default_policy": "mirror",
      "import_strategy": "tier 3 已有则不备份；tier 3 缺失才备份并放分享链接"
    },
    "5": {
      "label": "杂源 / 灰色 / 私人盘",
      "description": "Anna's Archive / z-library / 论坛 / 私人网盘",
      "default_policy": "download_only",
      "import_strategy": "仅用于下载工作流，不收录到 Book.resources"
    }
  },

  "policy_definitions": {
    "preserve": "直接录到 Book.resources，保留原始 URL",
    "mirror": "我们做的镜像，通过 group 字段绑到原始 resource，带 group_role=mirror",
    "download_only": "仅作为内部下载来源，不写入 Book.resources",
    "drop": "已有更优替代或不再合适收录，老条目应清理"
  },

