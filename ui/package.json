{
  "name": "book-index-ui",
  "version": "0.1.7",
  "description": "React components for browsing and editing ancient book index metadata",
  "author": "Li Shaodong",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-guji/book-index-manager.git",
    "directory": "ui"
  },
  "homepage": "https://github.com/open-guji/book-index-manager/tree/main/ui",
  "keywords": [
    "ancient-books",
    "book-index",
    "metadata",
    "classical-chinese",
    "react-components"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js",
      "require": "./dist/storage.cjs"
    },
    "./styles": "./dist/book-index-ui.css"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "vite build --mode lib",
    "watch:lib": "vite build --mode lib --watch",
    "build:app": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "opencc-js": ">=1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "opencc-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "opencc-js": "^1.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "license": "Apache-2.0"
}
